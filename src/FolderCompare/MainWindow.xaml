<Window x:Class="FolderCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolderCompare"
        xmlns:converters="clr-namespace:FolderCompare.Converters"
        xmlns:models="clr-namespace:FolderCompare.Models"
        mc:Ignorable="d"
        Title="Folder Compare"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== TOP AREA: Folder Selection Toolbar ==================== -->
        <Border Grid.Row="0" Background="#F5F6FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Row 1: Left Folder -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Left Folder:" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding LeftFolderPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" />
                <Button Grid.Row="0" Grid.Column="2"
                        Content="Browse…"
                        Command="{Binding BrowseLeftCommand}"
                        Style="{StaticResource BaseButtonStyle}" />

                <!-- Row 2: Right Folder -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Right Folder:" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding RightFolderPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" />
                <Button Grid.Row="2" Grid.Column="2"
                        Content="Browse…"
                        Command="{Binding BrowseRightCommand}"
                        Style="{StaticResource BaseButtonStyle}" />

                <!-- Row 3: Compare / Cancel -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="&#x25B6; Compare"
                            Command="{Binding CompareCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CancelButtonStyle}"
                            Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="10,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== FILTER BAR ==================== -->
        <Border Grid.Row="1" Background="#FAFBFC" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource LinkButtonStyle}" />
                    <TextBlock Text="|" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="4,0" />
                    <Button Content="Select None"
                            Command="{Binding SelectNoneCommand}"
                            Style="{StaticResource LinkButtonStyle}" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding StatusFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,16,0" VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,5,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                            BorderBrush="#AAAAAA" BorderThickness="1" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding Label, Mode=OneWay}" />
                                        <Run Text="(" /><Run Text="{Binding Count, Mode=OneWay}" /><Run Text=")" />
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ==================== PROGRESS BAR ==================== -->
        <ProgressBar Grid.Row="2"
                     Height="4"
                     Minimum="0" Maximum="100"
                     Value="{Binding ProgressPercent, Mode=OneWay}"
                     Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}"
                     Foreground="{StaticResource PrimaryAccentBrush}"
                     Background="#E0E0E0"
                     BorderThickness="0" />

        <!-- ==================== MAIN CONTENT: DataGrid ==================== -->
        <DataGrid Grid.Row="3"
                  x:Name="ResultsGrid"
                  ItemsSource="{Binding FilteredItems}"
                  Style="{StaticResource ComparisonDataGridStyle}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background"
                            Value="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" />
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_DoubleClick" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <!-- Status Icon -->
                <DataGridTextColumn Header="" Width="36"
                                    Binding="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                    CanUserSort="True" SortMemberPath="Status">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontSize" Value="14" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Status Text -->
                <DataGridTextColumn Header="Status" Width="100"
                                    Binding="{Binding Status}"
                                    CanUserSort="True" SortMemberPath="Status">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Name -->
                <DataGridTextColumn Header="Name" Width="200"
                                    Binding="{Binding Name}"
                                    CanUserSort="True" SortMemberPath="Name" />

                <!-- Relative Path -->
                <DataGridTextColumn Header="Relative Path" Width="*"
                                    Binding="{Binding RelativePath}"
                                    CanUserSort="True" SortMemberPath="RelativePath" />

                <!-- Left Size -->
                <DataGridTextColumn Header="Left Size" Width="90"
                                    Binding="{Binding LeftSize, Converter={StaticResource FileSizeConverter}}"
                                    CanUserSort="True" SortMemberPath="LeftSize">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Right Size -->
                <DataGridTextColumn Header="Right Size" Width="90"
                                    Binding="{Binding RightSize, Converter={StaticResource FileSizeConverter}}"
                                    CanUserSort="True" SortMemberPath="RightSize">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Left Modified -->
                <DataGridTextColumn Header="Left Modified" Width="140"
                                    Binding="{Binding LeftModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                    CanUserSort="True" SortMemberPath="LeftModified" />

                <!-- Right Modified -->
                <DataGridTextColumn Header="Right Modified" Width="140"
                                    Binding="{Binding RightModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                    CanUserSort="True" SortMemberPath="RightModified" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ==================== STATUS BAR ==================== -->
        <Border Grid.Row="4" Style="{StaticResource StatusBarStyle}">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="White" FontSize="12" />
        </Border>
    </Grid>
</Window>
