<Window x:Class="FolderCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolderCompare"
        xmlns:converters="clr-namespace:FolderCompare.Converters"
        xmlns:models="clr-namespace:FolderCompare.Models"
        mc:Ignorable="d"
        Title="Folder Compare"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="White">

      <Window.Resources>
          <converters:DepthToMarginConverter x:Key="DepthToMarginConverter" IndentPerLevel="20" />
      </Window.Resources>

      <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== TOP AREA: Folder Selection Toolbar ==================== -->
        <Border Grid.Row="0" Background="#F5F6FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Row 1: Left Folder -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Left Folder:" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding LeftFolderPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" />
                <Button Grid.Row="0" Grid.Column="2"
                        Content="Browse…"
                        Command="{Binding BrowseLeftCommand}"
                        Style="{StaticResource BaseButtonStyle}" />

                <!-- Row 2: Right Folder -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Right Folder:" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding RightFolderPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" />
                <Button Grid.Row="2" Grid.Column="2"
                        Content="Browse…"
                        Command="{Binding BrowseRightCommand}"
                        Style="{StaticResource BaseButtonStyle}" />

                <!-- Row 3: Compare / Cancel -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="&#x25B6; Compare"
                            Command="{Binding CompareCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CancelButtonStyle}"
                            Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="10,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== FILTER BAR ==================== -->
        <Border Grid.Row="1" Background="#FAFBFC" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource LinkButtonStyle}" />
                    <TextBlock Text="|" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="4,0" />
                    <Button Content="Select None"
                            Command="{Binding SelectNoneCommand}"
                            Style="{StaticResource LinkButtonStyle}" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding StatusFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,16,0" VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,5,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                            BorderBrush="#AAAAAA" BorderThickness="1" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding Label, Mode=OneWay}" />
                                        <Run Text="(" /><Run Text="{Binding Count, Mode=OneWay}" /><Run Text=")" />
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ==================== PROGRESS BAR ==================== -->
        <ProgressBar Grid.Row="2"
                     Height="4"
                     Minimum="0" Maximum="100"
                     Value="{Binding ProgressPercent, Mode=OneWay}"
                     Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}"
                     Foreground="{StaticResource PrimaryAccentBrush}"
                     Background="#E0E0E0"
                     BorderThickness="0" />

          <!-- ==================== MAIN CONTENT: Single ListView ==================== -->
          <ListView Grid.Row="3"
                    ItemsSource="{Binding UnifiedFlatItems}"
                    x:Name="MainListView">
              <ListView.View>
                  <GridView>
                      <GridViewColumn Header="Left Name" Width="250">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding Name}"
                                             Margin="{Binding Depth, Converter={StaticResource DepthToMarginConverter}}"
                                             FontWeight="{Binding IsDirectory, Converter={StaticResource FolderFontWeightConverter}}"
                                             VerticalAlignment="Center" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Left Ext" Width="80">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding LeftExtension}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsDirectory, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Left Size" Width="100">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding LeftSize, Converter={StaticResource FileSizeConverter}}"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsDirectory, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Left Modified" Width="140">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding LeftModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsDirectory, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Right Name" Width="250">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding Name}"
                                             Margin="{Binding Depth, Converter={StaticResource DepthToMarginConverter}}"
                                             FontWeight="{Binding IsDirectory, Converter={StaticResource FolderFontWeightConverter}}"
                                             VerticalAlignment="Center" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Right Ext" Width="80">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding RightExtension}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsDirectory, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Right Size" Width="100">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding RightSize, Converter={StaticResource FileSizeConverter}}"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsDirectory, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                      <GridViewColumn Header="Right Modified" Width="140">
                          <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding RightModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsDirectory, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
                              </DataTemplate>
                          </GridViewColumn.CellTemplate>
                      </GridViewColumn>
                  </GridView>
              </ListView.View>
              <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                      <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" />
                      <Setter Property="Margin" Value="0,1" />
                      <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick" />
                      <Style.Triggers>
                          <Trigger Property="IsSelected" Value="True">
                              <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
                              <Setter Property="Foreground" Value="White" />
                          </Trigger>
                      </Style.Triggers>
                  </Style>
              </ListView.ItemContainerStyle>
          </ListView>

        <!-- ==================== STATUS BAR ==================== -->
        <Border Grid.Row="4" Style="{StaticResource StatusBarStyle}">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="White" FontSize="12" />
        </Border>
    </Grid>
</Window>
