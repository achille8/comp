<Window x:Class="FolderCompare.FileCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FolderCompare.Converters"
        xmlns:models="clr-namespace:FolderCompare.Models"
        Title="{Binding WindowTitle}"
        Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="White">

    <Window.Resources>
        <converters:DiffTypeToBrushConverter x:Key="DiffTypeToBrushConverter" />
        <converters:DiffTypeToSymbolConverter x:Key="DiffTypeToSymbolConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== HEADER: File Paths ==================== -->
        <Border Grid.Row="0" Background="#2D3436" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding LeftFilePath}"
                           Foreground="White" FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="⟷" Foreground="#888888"
                           FontSize="14" Margin="12,0"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="2"
                           Text="{Binding RightFilePath}"
                           Foreground="White" FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT: Diff DataGrid ==================== -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding DiffLines}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Vertical"
                  VerticalGridLinesBrush="#E0E0E0"
                  SelectionUnit="FullRow"
                  SelectionMode="Single"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  FontFamily="Consolas" FontSize="12"
                  BorderThickness="0"
                  HeadersVisibility="Column"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background"
                            Value="{Binding Type, Converter={StaticResource DiffTypeToBrushConverter}}" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#B0BEC5" />
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Left Line Number -->
                <DataGridTextColumn Header="#" Width="50"
                                    Binding="{Binding LeftLineNumber}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="Padding" Value="0,0,6,0" />
                            <Setter Property="FontFamily" Value="Consolas" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Left Text -->
                <DataGridTextColumn Header="Left" Width="*"
                                    Binding="{Binding LeftText}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="Padding" Value="4,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Center Separator -->
                <DataGridTextColumn Header="" Width="30"
                                    Binding="{Binding Type, Converter={StaticResource DiffTypeToSymbolConverter}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Foreground" Value="#666666" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Right Line Number -->
                <DataGridTextColumn Header="#" Width="50"
                                    Binding="{Binding RightLineNumber}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="Padding" Value="0,0,6,0" />
                            <Setter Property="FontFamily" Value="Consolas" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Right Text -->
                <DataGridTextColumn Header="Right" Width="*"
                                    Binding="{Binding RightText}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="Padding" Value="4,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ==================== STATUS BAR ==================== -->
        <Border Grid.Row="2" Background="#2D3436" Padding="12,6">
            <TextBlock Text="{Binding SummaryText}"
                       Foreground="White" FontSize="12" />
        </Border>
    </Grid>
</Window>
